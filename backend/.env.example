# Environment Variables - Copy to .env and fill in values

# ─── LLM (Google Gemini - FREE) ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Get it free at: https://aistudio.google.com/app/apikey
GEMINI_MODEL=gemini-2.5-flash

# ─── Google Calendar API (Optional - demo mode works without this) ────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
# Get credentials at: https://console.cloud.google.com

# ─── Email Notifications (Optional) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
# For Gmail: use App Password (not your real password)
# Settings → Security → 2-Step Verification → App Passwords

# ─── App Config ───────────────────────────────────────────────────────────────
DEMO_MODE=true
DATABASE_URL=sqlite+aiosqlite:///./smart_timetable.db
SECRET_KEY=your-secret-key-change-in-production
FRONTEND_URL=http://localhost:3000
